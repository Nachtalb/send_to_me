{
  "manifest_version": 3,
  "name": "Send to Me",
  "version": "0.1.0",
  "description": "One-click send the current tab URL to your device via Telegram, webhooks, or QR code.",
  "permissions": ["storage", "contextMenus", "activeTab", "tabs", "notifications"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Send to Me"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
