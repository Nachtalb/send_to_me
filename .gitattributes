# Force LF on text files so Linux CI runners see consistent line endings
# even when the repo is checked out on Windows.
*.yml   text eol=lf
*.yaml  text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.css   text eol=lf
*.js    text eol=lf
*.html  text eol=lf
*.sh    text eol=lf

# Binary assets — never touch.
*.png   binary
*.jpg   binary
*.zip   binary
*.woff2 binary
